generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HOSPITAL_ADMIN
  DOCTOR
  PATIENT
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
  NO_SHOW
}

enum AppointmentType {
  IN_PERSON
  VIDEO
  CHAT
  PHONE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  STRIPE
  MOBILE_MONEY
  CARD
  CASH
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

enum NotificationType {
  APPOINTMENT_REMINDER
  NEW_MESSAGE
  PAYMENT_CONFIRMATION
  PRESCRIPTION
  MEDICAL_RECORD
  SYSTEM
  PROMOTION
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYMENT
  PRESCRIPTION
  APPOINTMENT
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  phone          String?
  password       String
  role           Role         @default(PATIENT)
  status         UserStatus   @default(PENDING)
  emailVerified  Boolean      @default(false)
  phoneVerified  Boolean      @default(false)
  twoFactorAuth  Boolean      @default(false)
  refreshToken   String?
  lastLoginAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  patientProfile  PatientProfile?
  doctorProfile   DoctorProfile?
  hospitalOwner   Hospital[]       @relation("HospitalOwner")
  hospitalAdmin   HospitalAdmin[]
  notifications   Notification[]
  reviews         Review[]
  favorites       Favorite[]
  payments        Payment[]
  auditLogs       AuditLog[]
  patientChats    Chat[]           @relation("PatientChats")
  doctorChats     Chat[]           @relation("DoctorChats")
  sentMessages    ChatMessage[]    @relation("SenderMessages")
  appointmentsAsPatient  Appointment[] @relation("PatientAppointments")
  appointmentsAsDoctor   Appointment[] @relation("DoctorAppointments")

  @@map("users")
}

model PatientProfile {
  id            String      @id @default(cuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String
  dateOfBirth   DateTime?
  gender        Gender?
  bloodGroup    BloodGroup?
  address       String?
  city          String?
  state         String?
  country       String?
  postalCode    String?
  emergencyContact String?
  emergencyPhone   String?
  avatarUrl     String?
  medicalHistory  String?
  allergies     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  medicalRecords MedicalRecord[]
  prescriptions Prescription[]

  @@map("patient_profiles")
}

model DoctorProfile {
  id            String      @id @default(cuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String
  specialty     String
  licenseNumber String      @unique
  yearsOfExperience Int     @default(0)
  biography     String?
  education     String?
  consultationFee Decimal   @default(0.0) @db.Decimal(10, 2)
  rating        Float       @default(0.0)
  reviewCount   Int         @default(0)
  avatarUrl     String?
  hospitalId    String?
  hospital      Hospital?   @relation(fields: [hospitalId], references: [id])
  isAvailable   Boolean     @default(true)
  maxPatientsPerDay Int     @default(20)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  availabilities Availability[]
  appointments   Appointment[]  @relation("DoctorProfileAppointments")
  medicalRecords MedicalRecord[]
  prescriptions Prescription[]
  reviews        Review[]
  favorites      Favorite[]

  @@map("doctor_profiles")
}

model Hospital {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  description   String?
  email         String?
  phone         String?
  address       String
  city          String
  state         String?
  country       String      @default("FR")
  postalCode    String?
  latitude      Float?
  longitude     Float?
  logoUrl       String?
  bannerUrl     String?
  website       String?
  status        UserStatus  @default(PENDING)
  isVerified    Boolean     @default(false)
  ownerId       String
  owner         User        @relation("HospitalOwner", fields: [ownerId], references: [id])
  subscriptionId String?
  subscription  Subscription? @relation(fields: [subscriptionId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  doctors         DoctorProfile[]
  departments     Department[]
  admins          HospitalAdmin[]
  appointments    Appointment[]
  payments        Payment[]

  @@map("hospitals")
}

model HospitalAdmin {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, hospitalId])
  @@map("hospital_admins")
}

model Department {
  id         String   @id @default(cuid())
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  name       String
  description String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([hospitalId, name])
  @@map("departments")
}

model Appointment {
  id            String            @id @default(cuid())
  patientId     String
  patient       User              @relation("PatientAppointments", fields: [patientId], references: [id])
  doctorId      String
  doctor        User              @relation("DoctorAppointments", fields: [doctorId], references: [id])
  doctorProfileId String
  doctorProfile DoctorProfile     @relation("DoctorProfileAppointments", fields: [doctorProfileId], references: [id])
  hospitalId    String
  hospital      Hospital          @relation(fields: [hospitalId], references: [id])
  date          DateTime
  endDate       DateTime
  status        AppointmentStatus @default(PENDING)
  type          AppointmentType   @default(IN_PERSON)
  reason        String?
  notes         String?
  cancellationReason String?
  rescheduleCount Int             @default(0)
  videoRoomUrl  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  payment     Payment?
  reminders   Notification[]

  @@index([patientId])
  @@index([doctorId])
  @@index([hospitalId])
  @@index([date])
  @@map("appointments")
}

model MedicalRecord {
  id          String   @id @default(cuid())
  patientId   String
  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId    String
  doctor      DoctorProfile  @relation(fields: [doctorId], references: [id])
  diagnosis   String?
  symptoms    String?
  notes       String?
  attachments String[]
  isConfidential Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([patientId])
  @@map("medical_records")
}

model Prescription {
  id            String   @id @default(cuid())
  patientId     String
  patient       PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId      String
  doctor        DoctorProfile  @relation(fields: [doctorId], references: [id])
  medications   Json
  diagnosis     String?
  notes         String?
  validUntil    DateTime?
  isRefillable  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId])
  @@map("prescriptions")
}

model Availability {
  id          String   @id @default(cuid())
  doctorId    String
  doctor      DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  dayOfWeek   WeekDay
  startTime   String
  endTime     String
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([doctorId, dayOfWeek, startTime])
  @@map("availabilities")
}

model Chat {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String
  patient   User     @relation("PatientChats", fields: [patientId], references: [id])
  doctor    User     @relation("DoctorChats", fields: [doctorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@unique([patientId, doctorId])
  @@map("chats")
}

model ChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("SenderMessages", fields: [senderId], references: [id])
  content   String
  fileUrl   String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([senderId])
  @@map("chat_messages")
}

model Payment {
  id              String        @id @default(cuid())
  appointmentId   String        @unique
  appointment     Appointment   @relation(fields: [appointmentId], references: [id])
  patientId       String
  patient         User          @relation(fields: [patientId], references: [id])
  hospitalId      String
  hospital        Hospital      @relation(fields: [hospitalId], references: [id])
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("EUR")
  status          PaymentStatus @default(PENDING)
  method          PaymentMethod
  transactionId   String?
  stripePaymentId String?
  mobileMoneyRef  String?
  invoiceUrl      String?
  invoicePdfUrl   String?
  paidAt          DateTime?
  refundedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([patientId])
  @@index([hospitalId])
  @@index([appointmentId])
  @@map("payments")
}

model Subscription {
  id            String             @id @default(cuid())
  hospitalId    String             @unique
  plan          String
  status        SubscriptionStatus @default(TRIAL)
  price         Decimal            @db.Decimal(10, 2)
  startDate     DateTime           @default(now())
  endDate       DateTime
  trialEndDate  DateTime?
  autoRenew     Boolean            @default(true)
  stripeSubId   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  hospitals Hospital[]

  @@map("subscriptions")
}

model Notification {
  id      String           @id @default(cuid())
  userId  String
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type    NotificationType
  title   String
  message String
  data    Json?
  readAt  DateTime?
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  createdAt     DateTime     @default(now())

  @@index([userId, readAt])
  @@map("notifications")
}

model Review {
  id         String   @id @default(cuid())
  patientId  String
  patient    User     @relation(fields: [patientId], references: [id])
  doctorId   String
  doctor     DoctorProfile @relation(fields: [doctorId], references: [id])
  hospitalId String?
  rating     Int      @default(5)
  comment    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([patientId, doctorId])
  @@index([doctorId])
  @@map("reviews")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctorId  String?
  doctor    DoctorProfile? @relation(fields: [doctorId], references: [id])
  hospitalId String?
  createdAt DateTime @default(now())

  @@unique([userId, doctorId])
  @@unique([userId, hospitalId])
  @@map("favorites")
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  action     AuditAction
  entity     String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
